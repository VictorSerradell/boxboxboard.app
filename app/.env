# ─── iRacing OAuth2 ───────────────────────────────────────────────
# Solicita estas credenciales en: auth@iracing.com
# Documentación: https://oauth.iracing.com/oauth2/book/client_registration.html

IRACING_CLIENT_ID=tu_client_id_aqui
IRACING_CLIENT_SECRET=tu_client_secret_aqui

# URI de callback — debe coincidir EXACTAMENTE con la registrada en iRacing
# En desarrollo:
IRACING_REDIRECT_URI=http://localhost:3000/api/auth/callback/iracing
# En producción (cuando tengas dominio):
# IRACING_REDIRECT_URI=https://tudominio.com/api/auth/callback/iracing

# URL pública de la app (usada en redirects post-login)
NEXTAUTH_URL=http://localhost:3000

# ─── Opcional: Supabase para favoritos persistentes ───────────────
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_ANON_KEY=tu_anon_key
